# Dotypos API Configuration
DOTYPOS_API_URL=https://api.dotypos.com/v2
DOTYPOS_API_KEY=your_dotypos_api_key_here
DOTYPOS_CLOUD_ID=your_dotypos_cloud_id_here

# Email Provider Configuration
# Options: console (default), resend
EMAIL_PROVIDER=auto

# Resend Configuration (optional)
# Sign up at https://resend.com to get an API key
# If not provided, emails will be logged to console
RESEND_API_KEY=your_resend_api_key_here

# Email Configuration
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=DeskoHub
