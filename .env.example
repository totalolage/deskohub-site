# Dotypos OAuth Configuration (Client-accessible - Required)
NEXT_PUBLIC_DOTYPOS_CLIENT_ID=your_dotypos_client_id_here
NEXT_PUBLIC_DOTYPOS_CLIENT_SECRET=your_dotypos_client_secret_here

# Dotypos API Configuration (Server-only - Required)
DOTYPOS_REFRESH_TOKEN=your_dotypos_refresh_token_here

# Dotypos API Configuration 
DOTYPOS_API_URL=https://api.dotykacka.cz/v2
DOTYPOS_BRANCH_ID=128665136
DOTYPOS_CLOUD_ID=your_dotypos_cloud_id_here
DOTYPOS_EMPLOYEE_ID=your_dotypos_employee_id_here
DOTYPOS_API_TIMEOUT=30000

# Email Provider Configuration
# Options: console (default), resend
EMAIL_PROVIDER=console

# Resend Configuration 
# Sign up at https://resend.com to get an API key
# If not provided, emails will be logged to console
RESEND_API_KEY=your_resend_api_key_here

# Email Configuration
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=DeskoHub

# Statsig Feature Flags Configuration (Required)
# Sign up at https://statsig.com to get API keys
NEXT_PUBLIC_STATSIG_CLIENT_KEY=your_statsig_client_key_here
STATSIG_SERVER_API_KEY=your_statsig_server_api_key_here
