{
  "$schema": "https://v2-9-14.turborepo.dev/schema.json",
  "globalDependencies": [".env", ".env.local"],
  "tasks": {
    "deskohub-workspace#build": {
      "env": ["CLOUDINARY_API_KEY", "CLOUDINARY_API_SECRET", "EMAIL_API_KEY"]
    },
    "@deskohub/dotypos#generate": {
      "passThroughEnv": [
        "CLOUDINARY_API_KEY",
        "CLOUDINARY_API_SECRET",
        "EMAIL_API_KEY"
      ]
    },
    "@deskohub/nexi#generate": {},
    "deskohub-workspace#i18n:compile": {
      "passThroughEnv": [
        "CLOUDINARY_API_KEY",
        "CLOUDINARY_API_SECRET",
        "EMAIL_API_KEY"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env.production*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:app": {
      "cache": false,
      "persistent": true
    },
    "dev:assets": {
      "cache": false,
      "persistent": true
    },
    "dev:server": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "start:app": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "i18n:compile": {
      "outputs": ["features/i18n/paraglide/**"]
    }
  }
}
