{
  "$schema": "https://v2-9-14.turborepo.dev/schema.json",
  "globalDependencies": [".env", ".env.local"],
  "globalEnv": ["NODE_ENV", "VERCEL_ENV"],
  "globalPassThroughEnv": [
    "CHECKOUT_RETURN_STATE_TOKEN_SECRET",
    "CHECKOUT_PAY_STATE_KEYS",
    "CLOUDINARY_API_KEY",
    "CLOUDINARY_API_SECRET",
    "CRON_SECRET",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "DOTYPOS_API_TIMEOUT",
    "DOTYPOS_API_URL",
    "DOTYPOS_BRANCH_ID",
    "DOTYPOS_CLIENT_ID",
    "DOTYPOS_CLIENT_SECRET",
    "DOTYPOS_CLOUD_ID",
    "DOTYPOS_EMPLOYEE_ID",
    "DOTYPOS_REFRESH_TOKEN",
    "EMAIL_API_KEY",
    "GOOGLE_CALENDAR_ID",
    "GOOGLE_CALENDAR_PRIVATE_KEY",
    "GOOGLE_CALENDAR_SERVICE_ACCOUNT_EMAIL",
    "RESEND_WEBHOOK_SECRET",
    "NEXI_API_KEY",
    "NEXI_API_ORIGIN",
    "NEXI_CHECKOUT_CURRENCY_OVERRIDE",
    "NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME",
    "NEXT_PUBLIC_GTM_ID",
    "VERCEL",
    "VERCEL_*",
    "!VERCEL_ENV",
    "VERCEL_AUTOMATION_BYPASS_SECRET",
    "VERCEL_PROJECT_PRODUCTION_URL",
    "VERCEL_URL"
  ],
  "tasks": {
    "@deskohub/dotypos#generate": {
      "passThroughEnv": [
        "CLOUDINARY_API_KEY",
        "CLOUDINARY_API_SECRET",
        "EMAIL_API_KEY"
      ]
    },
    "@deskohub/nexi#generate": {},
    "deskohub-workspace#i18n:compile": {
      "outputs": ["features/i18n/paraglide/**"],
      "passThroughEnv": [
        "CLOUDINARY_API_KEY",
        "CLOUDINARY_API_SECRET",
        "EMAIL_API_KEY"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env.production*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:app": {
      "cache": false,
      "persistent": true
    },
    "dev:assets": {
      "cache": false,
      "persistent": true
    },
    "dev:server": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "start:app": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "i18n:compile": {
      "outputs": ["features/i18n/paraglide/**"]
    }
  }
}
