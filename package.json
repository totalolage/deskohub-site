{
  "name": "deskohub-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:boardgame": "turbo run build --filter=deskohub-boardgame-bar",
    "build:portal": "turbo run build --filter=deskohub-portal",
    "build:workspace": "turbo run build --filter=deskohub-workspace",
    "dev": "turbo run dev --parallel",
    "dev:boardgame": "turbo run dev --filter=deskohub-boardgame-bar",
    "dev:portal": "turbo run dev:app --filter=deskohub-portal",
    "dev:portal:assets": "turbo run dev:assets --filter=deskohub-portal",
    "dev:portal:server": "turbo run dev:server --filter=deskohub-portal",
    "dev:workspace": "turbo run dev --filter=deskohub-workspace",
    "lint": "turbo run lint",
    "lint:boardgame": "turbo run lint --filter=deskohub-boardgame-bar",
    "lint:portal": "turbo run lint --filter=deskohub-portal",
    "lint:workspace": "turbo run lint --filter=deskohub-workspace",
    "start:portal": "turbo run start --filter=deskohub-portal",
    "typecheck": "turbo run typecheck",
    "typecheck:boardgame": "turbo run typecheck --filter=deskohub-boardgame-bar",
    "typecheck:portal": "turbo run typecheck --filter=deskohub-portal",
    "typecheck:workspace": "turbo run typecheck --filter=deskohub-workspace",
    "format": "bunx biome check --write --unsafe .",
    "generate:dotypos": "turbo run generate --filter=@deskohub/dotypos"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/bun": "^1.3.4",
    "turbo": "^2.8.15"
  },
  "packageManager": "bun@1.3.10"
}
