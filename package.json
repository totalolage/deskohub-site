{
  "name": "my-v0-project",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "run-s i18n:compile next:build",
    "next:build": "bunx next build",
    "dev": "run-p dev:next dev:i18n",
    "dev:next": "bunx next dev",
    "dev:i18n": "chokidar \"i18n/messages/*.json\" -c \"bun i18n:compile\"",
    "predev:i18n": "bun i18n:compile",
    "i18n:compile": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./i18n/paraglide",
    "dotypos:generate": "cd features/dotypos/openapi && bunx openapi-ts",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write --unsafe .",
    "typecheck": "bunx tsc --noEmit",
    "validate": "run-p lint typecheck",
    "start": "bunx next start"
  },
