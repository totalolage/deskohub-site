{
  "name": "deskohub-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "run-s i18n:compile next:build",
    "next:build": "bun next build --turbo",
    "dev": "run-p dev:next dev:i18n",
    "dev:next": "bunx next dev --turbo",
    "dev:i18n": "chokidar \"features/i18n/messages/*.json\" -c \"bun i18n:compile\"",
    "predev:i18n": "bun i18n:compile",
    "i18n:compile": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./features/i18n/paraglide",
    "dotypos:generate": "cd features/dotypos/openapi && bunx openapi-ts",
    "lint": "bunx biome check .",
    "format": "bunx biome check --write --unsafe .",
    "typecheck": "bunx tsc --noEmit",
    "validate": "run-p lint typecheck",
    "start": "bunx next start"
  },
  "dependencies": {
    "@doist/react-interpolate": "^2.2.1",
    "@effect/platform-node": "^0.94.0",
    "@effect/schema": "^0.75.5",
    "@hey-api/client-fetch": "^0.13.1",
    "@hookform/resolvers": "^5.1.1",
    "@inlang/paraglide-js": "^2.2.0",
    "@next/third-parties": "^15.5.4",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-collapsible": "1.1.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.3.0",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@vercel/analytics": "^1.5.0",
    "arktype": "^2.1.20",
    "autoprefixer": "^10.4.20",
    "botid": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.7.0",
    "clsx": "^2.1.1",
    "date-fns": "4.1.0",
    "effect": "^3.17.2",
    "js-cookie": "^3.0.5",
    "leaflet": "^1.9.4",
    "libphonenumber-js": "^1.12.10",
    "lucide-react": "^0.525.0",
    "next": "^16.0.7",
    "next-cloudinary": "^6.16.0",
    "next-safe-action": "^8.0.7",
    "next-themes": "^0.4.4",
    "react": "19.1.0",
    "react-day-picker": "8.10.1",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.60.0",
    "react-leaflet": "^5.0.0",
    "resend": "^6.0.1",
    "server-only": "^0.0.1",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "vanilla-cookieconsent": "^3.1.0",
    "yet-another-react-lightbox": "^3.25.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.0",
    "@hey-api/openapi-ts": "^0.80.11",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.4",
    "@types/js-cookie": "^3.0.6",
    "@types/leaflet": "^1.9.20",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "chokidar-cli": "^3.0.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  },
  "packageManager": "bun@1.2.19"
}
