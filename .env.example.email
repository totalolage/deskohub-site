# Email Service Configuration
# Copy these to your .env file and configure as needed

# Email Provider Selection
# Options: console, resend, smtp, sendgrid, mailgun
# Default: console (logs to console, no actual sending)
EMAIL_PROVIDER=console

# Default From Address
EMAIL_FROM_ADDRESS=noreply@mail.deskohub.cz
EMAIL_FROM_NAME=DeskohHub

# Provider-specific configuration

# For Resend
# EMAIL_PROVIDER=resend
# EMAIL_API_KEY=re_xxxxxxxxxxxxx

# For SMTP
# EMAIL_PROVIDER=smtp
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=your-email@gmail.com
# EMAIL_SMTP_PASSWORD=your-app-password
# EMAIL_SMTP_SECURE=true

# For SendGrid
# EMAIL_PROVIDER=sendgrid
# EMAIL_API_KEY=SG.xxxxxxxxxxxxx

# For Mailgun
# EMAIL_PROVIDER=mailgun
# EMAIL_API_KEY=key-xxxxxxxxxxxxx

# Test Mode (doesn't actually send emails, just logs)
EMAIL_TEST_MODE=false