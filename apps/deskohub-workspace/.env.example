# Workspace app env example
# Copy to apps/deskohub-workspace/.env.local for shared app defaults.
# Use apps/deskohub-workspace/.env.development.local for developer-only overrides.

# Server
WORKSPACE_API_URL=https://workspace-api.example.com
WORKSPACE_INTERNAL_API_KEY=replace_me
NEXI_API_ORIGIN=https://xpaysandbox.nexigroup.com
NEXI_API_KEY=replace_me
VERCEL_ENV=development
VERCEL_URL=workspace-git-branch-team.vercel.app
VERCEL_PROJECT_PRODUCTION_URL=workspace.example.com

# Client
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=replace_me
NEXT_PUBLIC_GTM_ID=GTM-T9MB5LF3
NEXT_PUBLIC_WORKSPACE_ENV=development

# Cloudinary webhook signing
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me
