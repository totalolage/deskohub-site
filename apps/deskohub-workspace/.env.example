# Workspace app env example
# Copy to apps/deskohub-workspace/.env.local for shared app defaults.
# Use apps/deskohub-workspace/.env.development.local for developer-only overrides.

# Database
# User-provided Postgres connection string. No database exists yet; provision one,
# set this value, then generate/apply fresh Drizzle migrations from db/schema.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Nexi payment API
NEXI_API_ORIGIN=https://xpaysandbox.nexigroup.com
NEXI_API_KEY=replace_me

# Checkout return-state token hashing pepper. Generate at least 32 random chars.
CHECKOUT_RETURN_STATE_TOKEN_SECRET=replace_with_32_plus_random_characters

# Vercel callback URL discovery
# Vercel provides these automatically on deployments. These local values are
# deployment stand-ins only; local Nexi HPP callbacks need a real HTTPS URL
# reachable by Nexi, or use a Vercel preview deployment.
VERCEL_ENV=development
VERCEL_URL=localhost:3000
VERCEL_PROJECT_PRODUCTION_URL=workspace.deskohub.cz

# Dotypos API
# Workspace reservation fulfillment selects an active visible Dotypos table by
# table tags. Configure tables with tier tags (`tier:basic`, `tier:plus`,
# `tier:profi`) and Profi monitor tags (`monitor:count:2`, `monitor:size:27|32`,
# `monitor:resolution:qhd|4k`).
DOTYPOS_API_URL=https://api.dotykacka.cz
DOTYPOS_API_TIMEOUT=30000
DOTYPOS_CLIENT_ID=replace_me
DOTYPOS_CLIENT_SECRET=replace_me
DOTYPOS_REFRESH_TOKEN=replace_me
DOTYPOS_CLOUD_ID=replace_me
DOTYPOS_BRANCH_ID=replace_me
DOTYPOS_EMPLOYEE_ID=replace_me

# Email service
# Workspace supports resend, smtp, sendgrid, mailgun, and console providers.
# Production/preview should use the same real provider as live contact/manual reservations.
EMAIL_PROVIDER=resend
EMAIL_API_KEY=replace_me
EMAIL_FROM_ADDRESS=noreply@mail.deskohub.cz
EMAIL_FROM_NAME=Deskohub
EMAIL_TEST_MODE=false

# Optional SMTP settings, only needed when EMAIL_PROVIDER=smtp.
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_SMTP_PORT=465
# EMAIL_SMTP_USER=replace_me
# EMAIL_SMTP_PASSWORD=replace_me
# EMAIL_SMTP_SECURE=true

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

# Client analytics/runtime flags
NEXT_PUBLIC_GTM_ID=GTM-T9MB5LF3
