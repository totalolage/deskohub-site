{
  "$schema": "https://v2-9-14.turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": [
        "@deskohub/dotypos#generate",
        "@deskohub/nexi#generate",
        "i18n:compile"
      ],
      "env": [
        "DOTYPOS_API_TIMEOUT",
        "NEXI_API_ORIGIN",
        "NEXI_CHECKOUT_CURRENCY_OVERRIDE",
        "NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME",
        "NEXT_PUBLIC_GTM_ID",
        "NEXT_PUBLIC_POSTHOG_HOST",
        "POSTHOG_API_KEY",
        "POSTHOG_PROJECT_ID",
        "VERCEL_PROJECT_PRODUCTION_URL",
        "WORKSPACE_CALLBACK_ORIGIN",
        "WORKSPACE_E2E_BOTID_BYPASS"
      ]
    },
    "i18n:compile": {
      "env": ["!NEXT_PUBLIC_VERCEL_*"],
      "inputs": [
        "features/i18n/messages/*.json",
        "project.inlang/settings.json",
        "project.inlang/project_id"
      ],
      "outputs": ["features/i18n/paraglide/**"]
    },
    "db:migrate": {
      "cache": false,
      "env": ["DATABASE_URL", "DATABASE_URL_UNPOOLED"]
    },
    "dev": {
      "dependsOn": [
        "@deskohub/dotypos#generate",
        "@deskohub/nexi#generate",
        "i18n:compile"
      ]
    },
    "test": {
      "dependsOn": [
        "$TURBO_EXTENDS$",
        "@deskohub/dotypos#generate",
        "@deskohub/nexi#generate",
        "i18n:compile"
      ]
    },
    "typecheck": {
      "dependsOn": ["@deskohub/nexi#generate", "i18n:compile"]
    }
  }
}
