{
  "$schema": "https://v2-9-14.turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": [
        "@deskohub/dotypos#generate",
        "@deskohub/nexi#generate",
        "i18n:compile"
      ],
      "env": [
        "NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME",
        "NEXT_PUBLIC_GTM_ID",
        "VERCEL_PROJECT_PRODUCTION_URL",
        "VERCEL_URL"
      ]
    },
    "build:vercel": {
      "dependsOn": ["db:migrate", "build"],
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "dev": {
      "dependsOn": [
        "@deskohub/dotypos#generate",
        "@deskohub/nexi#generate",
        "i18n:compile"
      ]
    },
    "typecheck": {
      "dependsOn": ["@deskohub/nexi#generate", "i18n:compile"]
    }
  }
}
