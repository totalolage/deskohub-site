{
  "$schema": "https://v2-9-14.turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": [
        "@deskohub/dotypos#generate",
        "@deskohub/nexi#generate",
        "i18n:compile"
      ],
      "env": [
        "DOTYPOS_CLIENT_ID",
        "DOTYPOS_CLIENT_SECRET",
        "DOTYPOS_REFRESH_TOKEN",
        "DOTYPOS_API_URL",
        "DOTYPOS_BRANCH_ID",
        "DOTYPOS_CLOUD_ID",
        "DOTYPOS_EMPLOYEE_ID",
        "DOTYPOS_API_TIMEOUT",
        "DOTYPOS_WEBHOOK_SECRET",
        "WORKSPACE_DOTYPOS_TABLE_ID",
        "EMAIL_API_KEY",
        "NEXI_API_KEY",
        "NEXI_API_ORIGIN",
        "NEXI_CHECKOUT_CURRENCY_OVERRIDE",
        "CLOUDINARY_API_KEY",
        "CLOUDINARY_API_SECRET",
        "DATABASE_URL",
        "NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME",
        "NEXT_PUBLIC_GTM_ID"
      ]
    },
    "build:vercel": {
      "dependsOn": ["db:migrate", "build"],
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "dev": {
      "dependsOn": [
        "@deskohub/dotypos#generate",
        "@deskohub/nexi#generate",
        "i18n:compile"
      ],
      "passThroughEnv": [
        "CLOUDINARY_API_KEY",
        "CLOUDINARY_API_SECRET",
        "DATABASE_URL",
        "DOTYPOS_API_TIMEOUT",
        "DOTYPOS_API_URL",
        "DOTYPOS_BRANCH_ID",
        "DOTYPOS_CLIENT_ID",
        "DOTYPOS_CLIENT_SECRET",
        "DOTYPOS_CLOUD_ID",
        "DOTYPOS_EMPLOYEE_ID",
        "DOTYPOS_REFRESH_TOKEN",
        "DOTYPOS_WEBHOOK_SECRET",
        "WORKSPACE_DOTYPOS_TABLE_ID",
        "EMAIL_API_KEY",
        "NEXI_API_KEY",
        "NEXI_API_ORIGIN",
        "NEXI_CHECKOUT_CURRENCY_OVERRIDE",
        "NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME",
        "NEXT_PUBLIC_GTM_ID"
      ]
    },
    "typecheck": {
      "dependsOn": ["@deskohub/nexi#generate", "i18n:compile"]
    }
  }
}
