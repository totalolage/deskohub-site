{
  "name": "deskohub-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "bun run i18n:compile && next build --turbo",
    "dev": "bun run i18n:compile && next dev --turbo",
    "i18n:compile": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./features/i18n/paraglide",
    "lint": "biome check . --config-path ../../biome.json --vcs-root ../../",
    "typecheck": "bun run i18n:compile && tsc --noEmit",
    "start": "next start"
  },
  "dependencies": {
    "@deskohub/i18n": "workspace:*",
    "@inlang/paraglide-js": "^2.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@t3-oss/env-nextjs": "^0.13.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.17.2",
    "lucide-react": "^0.545.0",
    "next": "^16.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@tailwindcss/typography": "^0.5.19",
    "@effect/language-service": "^0.62.5",
    "@types/node": "^22",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  }
}
