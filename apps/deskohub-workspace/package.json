{
  "name": "deskohub-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "bun run i18n:compile && next build --turbo",
    "dev": "bun --parallel dev:next dev:i18n",
    "dev:next": "next dev --turbo",
    "dev:i18n": "chokidar \"features/i18n/messages/*.json\" -c \"bun i18n:compile\"",
    "i18n:compile": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./features/i18n/paraglide",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "biome check app db features shared proxy.ts --config-path ../../biome.json --vcs-root ../../",
    "typecheck": "bun run i18n:compile && tsc --noEmit",
    "start": "next start"
  },
  "dependencies": {
    "@deskohub/cloudinary": "workspace:*",
    "@deskohub/dotypos": "workspace:*",
    "@deskohub/email": "workspace:*",
    "@deskohub/i18n": "workspace:*",
    "@effect/schema": "^0.75.5",
    "@hookform/resolvers": "^5.2.2",
    "@inlang/paraglide-js": "^2.2.0",
    "@next/third-parties": "^16.2.6",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tailwindcss/postcss": "^4.1.13",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.6.0",
    "botid": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.17.2",
    "libphonenumber-js": "^1.12.10",
    "lucide-react": "^0.545.0",
    "next": "^16.2.6",
    "next-safe-action": "^8.5.2",
    "pg": "^8.21.0",
    "react": "^19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.74.0",
    "react-photo-album": "^3.6.0",
    "tailwind-merge": "^3.3.1",
    "vanilla-cookieconsent": "^3.1.0",
    "vercel": "^54.4.1",
    "yet-another-react-lightbox": "^3.25.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@effect/language-service": "^0.62.5",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
