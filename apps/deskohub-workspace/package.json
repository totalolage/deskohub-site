{
  "name": "deskohub-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "run-s i18n:compile next:build",
    "next:build": "bunx next build --turbo",
    "dev": "run-p dev:next dev:i18n",
    "dev:next": "bunx next dev --turbo --port 3010",
    "dev:i18n": "chokidar \"features/i18n/messages/*.json\" -c \"bun i18n:compile\"",
    "predev:i18n": "bun i18n:compile",
    "i18n:compile": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./features/i18n/paraglide",
    "lint": "bunx biome check . --config-path ../../biome.json",
    "typecheck": "bunx tsc --noEmit",
    "start": "bunx next start"
  },
  "dependencies": {
    "@deskohub/workspace-shared": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.8",
    "effect": "^3.17.2",
    "next": "^16.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@inlang/paraglide-js": "^2.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@effect/language-service": "^0.62.5",
    "@types/node": "^22",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "chokidar-cli": "^3.0.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  }
}
