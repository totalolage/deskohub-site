{
  "name": "deskohub-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "next build --turbo",
    "vercel-build": "bun --sequential db:migrate 'turbo build'",
    "dev": "bun --parallel dev:next dev:i18n",
    "dev:next": "next dev --turbo",
    "dev:i18n": "chokidar \"features/i18n/messages/*.json\" -c \"bun i18n:compile\"",
    "i18n:compile": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./features/i18n/paraglide",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "e2e:checkout": "bun scripts/workspace-checkout-e2e.ts",
    "lint": "biome check app db features shared proxy.ts --config-path ../../biome.json --vcs-root ../../",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "start": "next start"
  },
  "dependencies": {
    "@deskohub/cloudinary": "workspace:*",
    "@deskohub/cloudinary-image": "workspace:*",
    "@deskohub/dotypos": "workspace:*",
    "@deskohub/email": "workspace:*",
    "@deskohub/google-calendar": "workspace:*",
    "@deskohub/i18n": "workspace:*",
    "@deskohub/nexi": "workspace:*",
    "@deskohub/next-effect": "workspace:*",
    "@deskohub/qr-code": "workspace:*",
    "@deskohub/standard-schema": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@inlang/paraglide-js": "^2.2.0",
    "@js-temporal/polyfill": "^0.5.1",
    "@next/third-parties": "^16.2.6",
    "@opentelemetry/api-logs": "^0.219.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@standard-schema/spec": "^1.1.0",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tailwindcss/postcss": "^4.1.13",
    "@tanstack/react-query": "^5.101.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.6.0",
    "@vercel/queue": "^0.3.1",
    "botid": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "effect": "4.0.0-beta.85",
    "libphonenumber-js": "^1.12.10",
    "lucide-react": "^0.545.0",
    "motion": "^12.40.0",
    "next": "^16.2.6",
    "next-safe-action": "^8.5.2",
    "osm": "workspace:*",
    "pg": "^8.21.0",
    "posthog-js": "^1.388.1",
    "posthog-node": "^5.38.0",
    "react": "^19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.0",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.74.0",
    "react-photo-album": "^3.6.0",
    "resend": "^6.0.1",
    "tailwind-merge": "^3.3.1",
    "vanilla-cookieconsent": "^3.1.0",
    "yet-another-react-lightbox": "^3.25.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@effect/language-service": "^0.86.2",
    "@happy-dom/global-registrator": "^20.10.1",
    "@testing-library/react": "^16.3.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "chokidar-cli": "^3.0.0",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
