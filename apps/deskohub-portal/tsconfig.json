{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "allowJs": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["astro/client"]
  },
  "include": [
    "src/**/*.astro",
    "src/**/*.ts",
    "features/**/*.ts",
    "astro.config.ts"
  ]
}
