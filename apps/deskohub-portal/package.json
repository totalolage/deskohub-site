{
  "name": "deskohub-portal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "vercel-build": "turbo build",
    "i18n:compile": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./features/i18n/paraglide",
    "dev:i18n": "chokidar \"features/i18n/messages/*.json\" -c \"bun i18n:compile\"",
    "dev:site": "astro dev --host 127.0.0.1 --port 4321 --strictPort",
    "dev": "bun --parallel dev:site dev:i18n",
    "lint": "biome check astro.config.ts src features package.json tsconfig.json turbo.jsonc .gitignore --config-path ../../biome.json --vcs-root ../../",
    "typecheck": "bun run i18n:compile && bunx astro check"
  },
  "dependencies": {
    "@astrojs/vercel": "10.0.4",
    "@inlang/paraglide-js": "^2.2.0",
    "astro": "6.1.8"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "chokidar-cli": "^3.0.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.14"
}
