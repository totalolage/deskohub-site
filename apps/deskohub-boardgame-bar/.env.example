# Boardgame Bar app env example
# Copy to apps/deskohub-boardgame-bar/.env.local for shared app defaults.
# Use apps/deskohub-boardgame-bar/.env.development.local for developer-only overrides.

# Public runtime
NEXT_PUBLIC_NODE_ENV=development
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# Optional Vercel preview domain (with or without protocol)
NEXT_PUBLIC_VERCEL_URL=preview.example.vercel.app

# Optional production domain override (with or without protocol)
VERCEL_PROJECT_PRODUCTION_URL=deskohub.example.com

# Dotypos server credentials
DOTYPOS_CLIENT_ID=your_dotypos_client_id
DOTYPOS_CLIENT_SECRET=your_dotypos_client_secret
DOTYPOS_REFRESH_TOKEN=your_dotypos_refresh_token
DOTYPOS_API_URL=https://api.dotykacka.cz/v2
DOTYPOS_BRANCH_ID=128665136
DOTYPOS_CLOUD_ID=your_dotypos_cloud_id
DOTYPOS_EMPLOYEE_ID=your_dotypos_employee_id
DOTYPOS_API_TIMEOUT=30000
DOTYPOS_WEBHOOK_SECRET=00000000-0000-0000-0000-000000000000

# Email
EMAIL_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Cloudinary server credentials
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Encryption key (base64-encoded 32-byte key)
FORM_DATA_ENC_SECRET=replace_with_44_char_base64_key
