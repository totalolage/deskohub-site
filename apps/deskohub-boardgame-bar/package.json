    "resend": "^6.0.1",
    "server-only": "^0.0.1",
    "simple-icons": "^16.6.1",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
