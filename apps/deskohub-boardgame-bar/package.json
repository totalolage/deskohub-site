    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.3.0",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tanstack/react-query": "^5.101.0",
    "@vercel/analytics": "^1.5.0",
    "arktype": "^2.1.20",
    "botid": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.7.0",
    "clsx": "^2.1.1",
    "date-fns": "4.1.0",
    "effect": "4.0.0-beta.85",
    "js-cookie": "^3.0.5",
