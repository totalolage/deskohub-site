{
  "name": "deskohub-boardgame-bar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build --turbo",
    "vercel-build": "turbo build",
    "dev": "bun --parallel dev:next dev:i18n",
    "dev:next": "next dev --turbo",
    "dev:i18n": "chokidar \"features/i18n/messages/*.json\" -c \"bun i18n:compile\"",
    "i18n:compile": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./features/i18n/paraglide",
    "lint": "biome check . --config-path ../../biome.json --vcs-root ../../",
    "typecheck": "tsc --noEmit",
    "start": "next start"
  },
  "dependencies": {
    "@deskohub/cloudinary": "workspace:*",
    "@deskohub/cloudinary-image": "workspace:*",
    "@deskohub/dotypos": "workspace:*",
