{
  "$schema": "https://v2-9-14.turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "feature-flags:check": {
      "cache": false,
      "env": [
        "POSTHOG_FEATURE_FLAGS_API_KEY",
        "POSTHOG_HOST",
        "POSTHOG_PROJECT_ID"
      ]
    },
    "feature-flags:sync": {
      "cache": false,
      "env": [
        "POSTHOG_FEATURE_FLAGS_API_KEY",
        "POSTHOG_HOST",
        "POSTHOG_PROJECT_ID"
      ],
      "outputs": ["src/generated/feature-flags.ts"]
    },
    "generate": {
      "cache": false,
      "env": ["POSTHOG_OPENAPI_SCHEMA_URL"],
      "outputs": ["src/generated/**"]
    },
    "typecheck": {
      "dependsOn": ["generate"]
    }
  }
}
